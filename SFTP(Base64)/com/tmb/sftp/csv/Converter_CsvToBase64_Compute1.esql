BROKER SCHEMA com.tmb.sftp.csv


CREATE COMPUTE MODULE Converter_CsvToBase64_Compute1
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		
		DECLARE base64String CHARACTER;
		DECLARE csvBlob BLOB InputRoot.BLOB.BLOB;		
		SET base64String = BASE64ENCODE(csvBlob);
		SET OutputRoot.JSON.Data.Base64CSV = base64String;
		
		RETURN TRUE;
	END;

	
END MODULE;
